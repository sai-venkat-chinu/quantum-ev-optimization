import numpy as np
import matplotlib.pyplot as plt

# Define EV energy consumption (weights)
weights = [3, 2, 1]  # EV1, EV2, EV3

# All possible states
states = [
    '000','001','010','011',
    '100','101','110','111'
]

valid_states = {}

# Constraints:
# 1. At least 1 EV must charge
# 2. At most 2 EVs can charge
for state in states:
    ones = state.count('1')
    
    if 1 <= ones <= 2:
        cost = 0
        for i in range(3):
            if state[i] == '1':
                cost += weights[i]
        
        valid_states[state] = cost

# Find optimal state (minimum cost)
best_state = min(valid_states, key=valid_states.get)

print("Valid States with Cost:", valid_states)
print("Optimal Charging State:", best_state)
print("Minimum Energy Cost:", valid_states[best_state])

# Plot
labels = list(valid_states.keys())
values = list(valid_states.values())

plt.bar(labels, values)
plt.title("Quantum-Inspired EV Charging Optimization (QUBO)")
plt.xlabel("Charging Combinations")
plt.ylabel("Energy Cost")
plt.show()
